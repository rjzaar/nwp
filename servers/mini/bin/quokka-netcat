#!/usr/bin/env bash
# quokka-netcat — crude netcat voice bridge to quokka on mini.
#
# Records audio locally, sends the WAV to mini over a TCP socket,
# mini processes (whisper + ollama + piper) and returns text + TTS audio.
#
# Usage:
#   quokka-netcat                     # defaults: mini:9999
#   quokka-netcat --host mini --port 9999
#
# Controls:
#   ENTER  — start recording; ENTER again — stop and send
#   /quit  — exit
#
# Requires on mini:
#   ncat -l -k -p 9999 --sh-exec ~/nwp/servers/mini/bin/quokka-netcat-handler
#
# Dependencies (workstation): parecord, paplay, sox, ncat (or nc), python3

set -euo pipefail

MINI_HOST="${QUOKKA_HOST:-mini}"
PORT=9999

while [[ $# -gt 0 ]]; do
    case "$1" in
        --host) MINI_HOST="$2"; shift 2 ;;
        --port) PORT="$2";      shift 2 ;;
        -h|--help) sed -n '2,15p' "$0"; exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 2 ;;
    esac
done

# Prefer ncat, fall back to nc
if command -v ncat >/dev/null 2>&1; then
    NC=ncat
elif command -v nc >/dev/null 2>&1; then
    NC=nc
else
    echo "missing: ncat or nc" >&2; exit 1
fi

for bin in arecord paplay sox python3; do
    command -v "$bin" >/dev/null 2>&1 || { echo "missing: $bin" >&2; exit 1; }
done

TMPDIR_LOCAL=$(mktemp -d -t quokka-nc.XXXXXX)
trap 'rm -rf "$TMPDIR_LOCAL"' EXIT

say()  { printf '\033[1;36m%s\033[0m\n' "$*"; }
user() { printf '\033[1;33m%s\033[0m\n' "$*"; }
dim()  { printf '\033[2m%s\033[0m\n' "$*"; }

# Binary-safe response parser: reads two text lines then dumps remaining bytes
parse_response() {
    local response_file="$1" transcript_file="$2" reply_file="$3" wav_file="$4"
    python3 -c "
import sys
with open('$response_file', 'rb') as f:
    data = f.read()
# Find first two newlines
i1 = data.index(b'\n')
i2 = data.index(b'\n', i1 + 1)
transcript = data[:i1].decode('utf-8', errors='replace')
reply = data[i1+1:i2].decode('utf-8', errors='replace')
wav = data[i2+1:]
with open('$transcript_file', 'w') as f: f.write(transcript)
with open('$reply_file', 'w') as f: f.write(reply)
with open('$wav_file', 'wb') as f: f.write(wav)
"
}

say "quokka-netcat ready  target=$MINI_HOST:$PORT"
dim "Press ENTER to speak, type /quit to exit."
dim "Make sure the listener is running on mini:"
dim "  ncat -l -k -p $PORT --sh-exec ~/nwp/servers/mini/bin/quokka-netcat-handler"

while true; do
    printf '\n\033[2m> \033[0m'
    read -r line
    case "${line:-}" in
        /quit) say "goodbye"; break ;;
    esac

    # Record locally
    raw_file="$TMPDIR_LOCAL/rec.raw"
    wav_file="$TMPDIR_LOCAL/rec.wav"
    dim "Recording — press ENTER to stop..."
    arecord -q -f S16_LE -r 16000 -c 1 "$wav_file" &
    rec_pid=$!
    read -r _
    kill -INT "$rec_pid" 2>/dev/null; wait "$rec_pid" 2>/dev/null || true

    wav_size=$(stat -c%s "$wav_file" 2>/dev/null || echo 0)
    if [[ "$wav_size" -le 100 ]]; then
        dim "(empty recording, skipping)"
        continue
    fi

    # Send WAV to mini, receive response
    dim "Sending to mini..."
    response_file="$TMPDIR_LOCAL/response.bin"
    $NC "$MINI_HOST" "$PORT" < "$wav_file" > "$response_file" 2>/dev/null

    if [[ ! -s "$response_file" ]]; then
        dim "(no response from mini — is the listener running?)"
        continue
    fi

    # Parse: line 1 = transcript, line 2 = reply, rest = WAV audio
    transcript_file="$TMPDIR_LOCAL/transcript.txt"
    reply_file="$TMPDIR_LOCAL/reply.txt"
    reply_wav="$TMPDIR_LOCAL/reply.wav"

    if ! parse_response "$response_file" "$transcript_file" "$reply_file" "$reply_wav" 2>/dev/null; then
        dim "(failed to parse response)"
        continue
    fi

    transcript=$(cat "$transcript_file")
    reply_text=$(cat "$reply_file")

    if [[ "$transcript" == "__BLANK__" || "$transcript" == "__EMPTY__" ]]; then
        dim "(no speech detected)"
        continue
    fi

    user "you: $transcript"
    say "mini: $reply_text"

    # Play TTS audio locally
    if [[ -s "$reply_wav" ]]; then
        paplay "$reply_wav" 2>/dev/null &
        wait $! 2>/dev/null || true
    fi
done
