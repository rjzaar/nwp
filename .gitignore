# NWP Infrastructure .gitignore
# This file ignores everything except the core NWP infrastructure files
# Users will have their own nwp.yml configuration (ignored)
# and their own site installations (ignored)

# Ignore everything by default
/*

# Whitelist NWP infrastructure files

# Sites directory (where site installations go)
# The folder is tracked but contents are ignored
!sites/
sites/*
!sites/.gitkeep

# sites/tmp/ is forbidden — see CLAUDE.md ("sites/tmp/ — NEVER CREATE").
# Explicit deny so even an accidental whitelist later in this file can't undo it.
sites/tmp/
sites/tmp/**

# /private/ holds operator-private handoff packs (Coder/Greg setup script,
# handbook, credentials). Defense in depth — explicit deny so even if a
# later whitelist accidentally re-includes it, this stays ignored.
private/
private/**

# Command entry points
# Users run ./setup.sh to bootstrap
# After setup, use the `pl` CLI command to run all other scripts
# (F23: legacy podcast.sh / install.sh root symlinks were removed; commands
#  live in scripts/commands/ and dispatch through `pl`.)
!setup.sh

# CLI completion (installed by setup)
!pl
!pl-completion.bash

# CI/CD and code quality
!.gitlab-ci.yml
!.github/
!.github/**
!.gitlab/
!.gitlab/**
!.hooks/
!.hooks/**
!renovate.json
!phpstan.neon

# Scripts directory
!scripts/
!scripts/**

# Rollback registry: per-host runtime data (snapshot paths point at
# specific remote files in the operator's home dir on the live host).
# Not portable, not for the repo. MUST come after the `!scripts/**`
# whitelist above so it actually wins.
scripts/commands/.rollback/
scripts/commands/.rollback/**

# Verification tracking
# .verification.yml is intentionally tracked: it documents which commands have
# been verified (real run vs. syntax-only) so badges and external readers can
# see what's actually exercised. It churns on every `pl verify` run, which is
# the price of that transparency.
!.verification.yml
!.badges.json
!.verification-scenarios/
!.verification-scenarios/**

# CI stats (F36 §6.5) — bootstrap config + readme tracked on main;
# runtime *.tsv samples live on the `stats` branch only (deny rule
# at the bottom of this file).
!.ci-stats/
!.ci-stats/README.md
!.ci-stats/bootstrap.yml

# Documentation and metadata
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!KNOWN_ISSUES.md
!LICENSE
!LICENSE-CC0
!LICENSE-MIT
!NOTICE
!CLAUDE.md

# Configuration templates (not user configs)
!example.nwp.yml
!.secrets.example.yml
!.secrets.data.example.yml
!.nwp-developer.example.yml

# Migration scripts (access via pl or scripts/commands/)

# Documentation directory
!docs/
!docs/**

# Libraries
!lib/
!lib/**

# Tests
!tests/
!tests/**

# Templates for new sites
!templates/
!templates/**

# F23 Phase 8: per-server infrastructure (email/, linode/, git/) now lives
# under servers/<name>/ — see the servers/ block below.
# F23 Phase 3: Mass Times scraper now lives in sites/mt/pipeline/.
# F23 Phase 2: Drupal custom modules now live in sites/<name>/web/modules/custom/.
# Pipelines and modules are intentionally untracked by the parent NWP repo
# (see the /sites/* rule above).

# Servers directory (per-host operator config — same pattern as sites/)
# Folder is tracked but contents are ignored. Per-host configs (wireguard,
# deploy scripts, server YAMLs) are operator-specific and never belong in
# the public tool repo. F33 (now SUPERSEDED) originally proposed moving
# these to a separate ~/nwp-instances/ repo; gitignoring matches sites/
# and is the simpler resolution.
!servers/
servers/*
!servers/.gitkeep
!servers/example-*.yml

# SSH keys directory (structure tracked, contents ignored)
!keys/
!keys/.gitkeep

# Keep .gitignore itself
!.gitignore

# P61 leakage-hygiene gate files (authored as part of P61 + F32 Phase A)
!.gitleaks.toml
!.gitleaksignore
!.pre-commit-config.yaml

# bin/ holds operational helper scripts (audit-authors, migrate-* per F33, etc.)
# tracked alongside lib/ and scripts/
!bin/
!bin/**

# However, always ignore secrets and local overrides anywhere in the tree
# SSH key contents (keep directory but ignore all keys)
keys/*
!keys/.gitkeep

# Secrets files - NEVER commit these
**/.secrets.yml
**/.secrets.yaml
**/.secrets.data.yml
**/.secrets.data.yaml
**/nwp.yml
**/.env.local
**/.ddev/config.local.yaml
**/.ddev/config.*.yaml
!**/.ddev/config.yaml
**/*.local.yml
**/*.local.yaml

# Generated output directories
scripts/commands/podcast-setup-*/

# CI stats runtime samples (F36 §6.5). Bootstrap config is checked in;
# *.tsv sample files live on the `stats` branch only.
.ci-stats/*.tsv

# Agent loop runtime state (P-agent-loop)
# The driver and helpers are tracked under scripts/agent-loop/; their state
# files and the kill switch are local-only.
.loop-paused
.agent-loop.state.json
/logs/
/logs/**
