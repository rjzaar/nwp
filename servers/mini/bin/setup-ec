#!/usr/bin/env bash
# setup-ec — Build and install voice-engine/ec for barge-in echo cancellation.
# Run once on mini. Installs ec to ~/.local/bin/ec
#
# ec is a small C binary that uses SpeexDSP to subtract the known speaker
# output from the mic input in real time, enabling the voice-agent to listen
# while still speaking (barge-in) without hearing its own echo.
#
# After install, voice-agent uses ec automatically when --hands-free is set.

set -euo pipefail

say() { printf '\033[1;36m%s\033[0m\n' "$*"; }
err() { printf '\033[1;31m%s\033[0m\n' "$*" >&2; }

# --- pre-flight --------------------------------------------------------------

if [[ -x "$HOME/.local/bin/ec" ]]; then
    say "ec is already installed at ~/.local/bin/ec"
    "$HOME/.local/bin/ec" -h 2>&1 | head -1 || true
    read -rp "Reinstall? [y/N] " ans
    [[ "$ans" =~ ^[Yy] ]] || { say "Nothing to do."; exit 0; }
fi

# --- install build deps ------------------------------------------------------

say "Installing build dependencies..."
sudo apt-get update -qq
sudo apt-get install -y --no-install-recommends \
    build-essential libasound2-dev libspeexdsp-dev

# --- clone and build ----------------------------------------------------------

BUILD_DIR=$(mktemp -d -t setup-ec.XXXXXX)
trap 'rm -rf "$BUILD_DIR"' EXIT

say "Cloning voice-engine/ec..."
git clone --depth 1 https://github.com/voice-engine/ec.git "$BUILD_DIR/ec"

say "Building..."
cd "$BUILD_DIR/ec"
make

# --- install ------------------------------------------------------------------

mkdir -p "$HOME/.local/bin"
cp ec "$HOME/.local/bin/ec"
chmod +x "$HOME/.local/bin/ec"

# --- verify -------------------------------------------------------------------

say ""
say "Installed: $(ls -lh "$HOME/.local/bin/ec" | awk '{print $5, $NF}')"
say ""
say "Done. ec is ready."
say "voice-agent will use it automatically for barge-in in hands-free mode."
