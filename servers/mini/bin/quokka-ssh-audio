#!/usr/bin/env bash
# quokka-ssh-audio — talk to quokka from the workstation over SSH.
#
# Full pipeline runs on mini (whisper + ollama + piper).
# Audio is captured and played on the LOCAL workstation, piped over SSH.
#
# Usage:
#   quokka-ssh-audio                     # defaults
#   quokka-ssh-audio --model qwen2.5-coder:14b
#
# Controls:
#   ENTER  — start recording; ENTER again — stop and send
#   /quit  — exit
#   /new   — reset conversation
#
# Dependencies (workstation): parecord, paplay, sox, jq, ssh
# Dependencies (mini):        whisper-cli, piper, ollama, jq

set -euo pipefail

MINI_HOST="${QUOKKA_HOST:-mini}"
MODEL="llama3.1:8b"
VOICE="en_GB-alba-medium"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model)  MODEL="$2";  shift 2 ;;
        --voice)  VOICE="$2";  shift 2 ;;
        --host)   MINI_HOST="$2"; shift 2 ;;
        -h|--help) sed -n '2,16p' "$0"; exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 2 ;;
    esac
done

# Pre-flight: local
for bin in arecord paplay sox ssh jq; do
    command -v "$bin" >/dev/null 2>&1 || { echo "missing: $bin" >&2; exit 1; }
done

# Pre-flight: remote
ssh -o ConnectTimeout=3 "$MINI_HOST" \
    "command -v ~/.local/bin/whisper-cli >/dev/null && command -v ~/.local/bin/piper >/dev/null && curl -sf http://127.0.0.1:11434/api/tags >/dev/null" \
    || { echo "mini pre-flight failed — check SSH, whisper, piper, ollama" >&2; exit 1; }

TMPDIR_LOCAL=$(mktemp -d -t quokka-ssh.XXXXXX)
trap 'rm -rf "$TMPDIR_LOCAL"' EXIT

SYSTEM_PROMPT='Your name is Quokka. You are a helpful voice assistant running locally on a Beelink mini-PC called mini. Your user is Rob. Keep spoken answers short — one to three sentences. When Rob asks you to write code, output ONLY the code with no explanation — it will be saved to a file. Start the code with a comment naming the language (e.g. # python, // javascript, -- lua). For non-code questions, answer conversationally. Avoid markdown formatting.'

say()  { printf '\033[1;36m%s\033[0m\n' "$*"; }
user() { printf '\033[1;33m%s\033[0m\n' "$*"; }
dim()  { printf '\033[2m%s\033[0m\n' "$*"; }

sanitize_for_speech() {
    sed \
        -e 's/```[a-z]*//g' -e 's/```//g' \
        -e 's/\*\*\([^*]*\)\*\*/\1/g' -e 's/\*\([^*]*\)\*/\1/g' \
        -e 's/__\([^_]*\)__/\1/g' -e 's/_\([^_]*\)_/\1/g' \
        -e 's/`\([^`]*\)`/\1/g' \
        -e 's/^[[:space:]]*[-*][[:space:]]//g' \
        -e 's/^[[:space:]]*[0-9]\{1,\}\.[[:space:]]//g' \
        -e 's/^#\{1,\}[[:space:]]//g' \
        -e 's|https\{0,1\}://[^ ]*||g' \
        | tr -s ' \n' ' ' | sed 's/^ //; s/ $//'
}

# Initialise conversation history on mini
SYSTEM_JSON=$(printf '%s' "$SYSTEM_PROMPT" | jq -Rs .)
ssh "$MINI_HOST" "mkdir -p /tmp/quokka-remote; echo '[{\"role\":\"system\",\"content\":$SYSTEM_JSON}]' > /tmp/quokka-remote/history.json"

say "quokka-ssh-audio ready  model=$MODEL  host=$MINI_HOST"
say "All processing on mini. Audio local to this workstation."
dim "Press ENTER to speak, type /quit to exit, /new to reset."

while true; do
    printf '\n\033[2m> \033[0m'
    read -r line
    case "${line:-}" in
        /quit) say "goodbye"; break ;;
        /new)
            ssh "$MINI_HOST" "echo '[{\"role\":\"system\",\"content\":$SYSTEM_JSON}]' > /tmp/quokka-remote/history.json"
            dim "conversation reset"
            continue ;;
    esac

    # --- Record locally ---
    raw_file="$TMPDIR_LOCAL/rec.raw"
    wav_file="$TMPDIR_LOCAL/rec.wav"
    dim "Recording — press ENTER to stop..."
    arecord -q -f S16_LE -r 16000 -c 1 "$wav_file" &
    rec_pid=$!
    read -r _
    kill -INT "$rec_pid" 2>/dev/null; wait "$rec_pid" 2>/dev/null || true

    wav_size=$(stat -c%s "$wav_file" 2>/dev/null || echo 0)
    if [[ "$wav_size" -le 100 ]]; then
        dim "(empty recording, skipping)"
        continue
    fi

    # --- Send WAV to mini, transcribe, think ---
    dim "Transcribing on mini..."

    # Upload recording
    scp -q "$wav_file" "$MINI_HOST:/tmp/quokka-remote/input.wav"

    # Run STT + LLM + TTS on mini; text reply comes on stdout
    reply=$(ssh "$MINI_HOST" bash << REMOTE
        set -euo pipefail
        WORKDIR=/tmp/quokka-remote
        HISTORY="\$WORKDIR/history.json"
        WHISPER_MODEL="\$HOME/.local/share/whisper/ggml-base.en.bin"
        VOICE_FILE="\$HOME/.local/share/piper/voices/${VOICE}.onnx"

        # STT
        ~/.local/bin/whisper-cli -m "\$WHISPER_MODEL" -f "\$WORKDIR/input.wav" \
            -nt -np -otxt -of "\$WORKDIR/transcript" 2>/dev/null
        text=\$(cat "\$WORKDIR/transcript.txt" 2>/dev/null | tr -s ' \n' ' ' | sed 's/^ //; s/ \$//')

        if [[ -z "\$text" || "\$text" == "[BLANK_AUDIO]" ]]; then
            echo "__BLANK__"
            exit 0
        fi

        # LLM
        jq --arg c "\$text" '. + [{"role":"user","content":\$c}]' "\$HISTORY" > "\$HISTORY.tmp"
        mv "\$HISTORY.tmp" "\$HISTORY"

        payload=\$(jq -n --arg model "$MODEL" --slurpfile msgs "\$HISTORY" \
            '{model:\$model, messages:\$msgs[0], stream:false, options:{num_ctx:4096}}')

        resp=\$(curl -sS -X POST http://127.0.0.1:11434/api/chat \
            -H "Content-Type: application/json" -d "\$payload")
        reply=\$(printf '%s' "\$resp" | jq -r '.message.content // .error // "<empty>"')

        jq --arg c "\$reply" '. + [{"role":"assistant","content":\$c}]' "\$HISTORY" > "\$HISTORY.tmp"
        mv "\$HISTORY.tmp" "\$HISTORY"

        # TTS
        clean=\$(printf '%s' "\$reply" | sed \
            -e 's/\`\`\`[a-z]*//g' -e 's/\`\`\`//g' \
            -e 's/\*\*\([^*]*\)\*\*/\1/g' -e 's/\*\([^*]*\)\*/\1/g' \
            -e 's/__\([^_]*\)__/\1/g' -e 's/_\([^_]*\)_/\1/g' \
            -e "s/\\\`\([^\\\`]*\)\\\`/\1/g" \
            -e 's/^#\{1,\}[[:space:]]//g' \
            -e 's|https\{0,1\}://[^ ]*||g' \
            | tr -s ' \n' ' ' | sed 's/^ //; s/ \$//')

        printf '%s' "\$clean" | ~/.local/bin/piper \
            --model "\$VOICE_FILE" \
            --output_file "\$WORKDIR/reply.wav" >/dev/null 2>&1

        # Output: first line is transcript, rest is reply
        echo "\$text"
        echo "---"
        echo "\$reply"
REMOTE
    )

    # Parse response
    if [[ "$reply" == "__BLANK__" ]]; then
        dim "(no speech detected)"
        continue
    fi

    transcript=$(echo "$reply" | sed -n '1p')
    llm_reply=$(echo "$reply" | sed '1,/^---$/d')

    user "you: $transcript"
    say "mini: $llm_reply"

    # --- Fetch TTS audio and play locally ---
    scp -q "$MINI_HOST:/tmp/quokka-remote/reply.wav" "$TMPDIR_LOCAL/reply.wav"
    paplay "$TMPDIR_LOCAL/reply.wav" 2>/dev/null &
    wait $! 2>/dev/null || true
done
