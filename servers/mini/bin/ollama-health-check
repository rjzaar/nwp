#!/usr/bin/env bash
# ollama-health-check — local fast-path health check for mini's LLM stack.
#
# Intended to be run by the `ollama-health.service` timer every 5 minutes.
# This is the on-mini counterpart to `pl mini llm health --quick` on dev:
# same five checks, no SSH round-trip, no benchmarks. Each run is a few
# hundred milliseconds.
#
# The dev-side `pl mini llm health` command is the authoritative human
# interface. This script exists so the timer can run cheaply without
# SSHing into mini from mini.
#
# Exit 0 if all checks pass, 1 otherwise. Failures are logged to the
# journal via systemd's StandardOutput=journal.
#
# Deployed from nwp repo: `servers/mini/bin/ollama-health-check`.
set -euo pipefail

MODEL_CHAT="llama3.1:8b"
MODEL_CODER="qwen2.5-coder:14b"

overall=0

check() {
    local label="$1"
    local status="$2"
    local detail="$3"
    if [[ "$status" == "ok" ]]; then
        echo "OK:   $label — $detail"
    else
        echo "FAIL: $label — $detail"
        overall=1
    fi
}

# 1. systemd unit
if state=$(systemctl --user is-active ollama.service 2>&1); then
    check "systemd unit" ok "$state"
else
    check "systemd unit" fail "${state:-<unreachable>}"
fi

# 2. Daemon reachable
http=$(curl -sS -o /dev/null -w "%{http_code}" --max-time 3 \
    http://127.0.0.1:11434/api/tags 2>/dev/null || echo "000")
if [[ "$http" == "200" ]]; then
    check "daemon reachable" ok "HTTP $http on /api/tags"
else
    check "daemon reachable" fail "HTTP $http on /api/tags"
fi

# 3. Loopback-only bind
listen=$(ss -tlnH 'sport = :11434' 2>/dev/null | awk '{print $4}' || true)
if [[ "$listen" == "127.0.0.1:11434" ]]; then
    check "loopback bind" ok "$listen"
else
    check "loopback bind" fail "${listen:-<no listener>} (expected 127.0.0.1:11434)"
fi

# 4+5. Models registered
if [[ "$http" == "200" ]]; then
    models=$(~/.local/bin/ollama list 2>/dev/null | awk 'NR>1 {print $1}') || models=""
    for model in "$MODEL_CHAT" "$MODEL_CODER"; do
        if grep -Fxq "$model" <<< "$models"; then
            check "model $model" ok "registered"
        else
            check "model $model" fail "NOT registered"
        fi
    done
else
    check "model $MODEL_CHAT"  fail "skipped (daemon unreachable)"
    check "model $MODEL_CODER" fail "skipped (daemon unreachable)"
fi

if [[ "$overall" -eq 0 ]]; then
    echo "mini LLM stack: HEALTHY"
else
    echo "mini LLM stack: UNHEALTHY"
fi

################################################################################
# Alerting: post to ops/mons-log on state transitions.
#
# We use a sentinel file at ~/.cache/ollama-health.state to remember the
# previous run's state. An alert is posted when:
#   - healthy -> unhealthy (a "went down" alert)
#   - unhealthy -> healthy (a "recovered" alert)
# No alert is posted when the state is unchanged, so a 1-hour outage is
# one alert not twelve.
#
# The token lives at ~/.config/mini-alerts.token (0600, scoped PAT that
# can ONLY post to ops/mons-log — no other project, no other action).
# If the token file is missing, alerting is silently skipped (useful for
# development).
################################################################################

STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
STATE_FILE="$STATE_DIR/ollama-health.state"
TOKEN_FILE="$HOME/.config/mini-alerts.token"
mkdir -p "$STATE_DIR"

prev_state="unknown"
if [[ -f "$STATE_FILE" ]]; then
    prev_state=$(cat "$STATE_FILE" 2>/dev/null || echo "unknown")
fi

if [[ "$overall" -eq 0 ]]; then
    new_state="healthy"
else
    new_state="unhealthy"
fi
echo "$new_state" > "$STATE_FILE"

# Only alert on transitions, and only if we have a token.
if [[ "$prev_state" != "unknown" ]] && \
   [[ "$prev_state" != "$new_state" ]] && \
   [[ -r "$TOKEN_FILE" ]]; then

    TOKEN=$(cat "$TOKEN_FILE")
    HOST=$(hostname)
    TS=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    if [[ "$new_state" == "unhealthy" ]]; then
        TITLE="mini LLM stack UNHEALTHY"
    else
        TITLE="mini LLM stack recovered (now HEALTHY)"
    fi

    # Body carries the full check output so the reader sees what failed.
    # Use the collected check output — we regenerate it here rather than
    # capturing the earlier echoes, because those went to stdout already.
    BODY="host: ${HOST}"$'\n'"time: ${TS}"$'\n'"transition: ${prev_state} -> ${new_state}"$'\n\n'"source: ollama-health.service on mini (F21 Phase 3a health check)"

    # Fire and forget — don't fail the check just because the alert
    # post failed. The journal still has the health state.
    curl -sS --max-time 10 \
        -X POST \
        -H "PRIVATE-TOKEN: ${TOKEN}" \
        --data-urlencode "title=${TITLE}" \
        --data-urlencode "description=${BODY}" \
        "https://git.nwpcode.org/api/v4/projects/ops%2Fmons-log/issues" \
        > /dev/null 2>&1 || echo "alerting: POST to ops/mons-log failed (non-fatal)"
fi

exit "$overall"
