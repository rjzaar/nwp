#!/usr/bin/env bash
# quokka-split — voice chat with quokka: local STT/TTS, remote LLM.
#
# Audio never leaves this workstation. Only text crosses the network.
# STT (whisper.cpp) and TTS (piper) run locally.
# LLM (ollama) runs on mini via an SSH tunnel.
#
# Usage:
#   quokka-split                         # push-to-talk (ENTER to record)
#   quokka-split --hands-free            # auto voice detection, Ctrl-C to quit
#   quokka-split --model qwen2.5-coder:14b
#   quokka-split --setup                 # install local whisper + piper from mini
#
# Push-to-talk controls:
#   ENTER  — start recording; ENTER again — stop and send
#   /quit  — exit
#   /new   — reset conversation
#
# Hands-free controls:
#   Just talk — sox detects voice onset and silence automatically
#   Ctrl-C   — quit
#
# Dependencies (workstation): parecord, paplay, sox, jq, ssh,
#   ~/.local/bin/whisper-cli, ~/.local/bin/piper (install with --setup)
# Dependencies (mini): ollama with llama3.1:8b loaded

set -euo pipefail

MINI_HOST="${QUOKKA_HOST:-mini}"
MODEL="llama3.1:8b"
LOCAL_BIN="$HOME/.local/bin"
WHISPER_CLI="$LOCAL_BIN/whisper-cli"
WHISPER_MODEL="$HOME/.local/share/whisper/ggml-base.en.bin"
WHISPER_LIB="$HOME/.local/lib/whisper"
PIPER_DIR="$HOME/.local/share/piper"
PIPER_BIN="$PIPER_DIR/piper"
VOICE="$PIPER_DIR/voices/en_GB-alba-medium.onnx"
OLLAMA_PORT=11434
TUNNEL_PORT=11435   # local port forwarded to mini's ollama
DO_SETUP=false
HANDS_FREE=false
# Sox silence-detection thresholds (tune via env vars)
SOX_ONSET_DURATION="${QUOKKA_ONSET:-0.3}"        # seconds of sound to start
SOX_ONSET_THRESHOLD="${QUOKKA_ONSET_DB:-10%}"     # voice must be above this to start
SOX_SILENCE_DURATION="${QUOKKA_SILENCE:-1.8}"     # seconds below threshold to stop
SOX_SILENCE_THRESHOLD="${QUOKKA_SILENCE_DB:-8%}"  # ambient peaks ~6.5%, so 8% = silence
SOX_MAX_DURATION="${QUOKKA_MAX_REC:-30}"          # hard cap per utterance

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model)      MODEL="$2";  shift 2 ;;
        --voice)      VOICE="$2";  shift 2 ;;
        --host)       MINI_HOST="$2"; shift 2 ;;
        --setup)      DO_SETUP=true; shift ;;
        --hands-free) HANDS_FREE=true; shift ;;
        -h|--help) sed -n '2,24p' "$0"; exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 2 ;;
    esac
done

say()  { printf '\033[1;36m%s\033[0m\n' "$*"; }
dim()  { printf '\033[2m%s\033[0m\n' "$*"; }
user() { printf '\033[1;33m%s\033[0m\n' "$*"; }

# ---------------------------------------------------------------------------
# --setup: copy whisper + piper + models from mini
# ---------------------------------------------------------------------------
if [[ "$DO_SETUP" == true ]]; then
    say "Setting up local whisper.cpp and piper from $MINI_HOST..."
    mkdir -p "$LOCAL_BIN" "$HOME/.local/share/whisper" "$PIPER_DIR/voices"

    # whisper-cli binary + model
    if [[ ! -x "$WHISPER_CLI" ]]; then
        dim "Copying whisper-cli..."
        scp "$MINI_HOST:~/.local/bin/whisper-cli" "$WHISPER_CLI"
        chmod +x "$WHISPER_CLI"
    else
        dim "whisper-cli already present"
    fi

    # whisper shared libraries
    mkdir -p "$WHISPER_LIB"
    if [[ ! -f "$WHISPER_LIB/libwhisper.so.1" ]]; then
        dim "Copying whisper shared libraries..."
        scp "$MINI_HOST:~/src/whisper.cpp/build/src/libwhisper.so.1" "$WHISPER_LIB/"
        scp "$MINI_HOST:~/src/whisper.cpp/build/ggml/src/libggml.so.0" "$WHISPER_LIB/"
        scp "$MINI_HOST:~/src/whisper.cpp/build/ggml/src/libggml-base.so.0" "$WHISPER_LIB/"
        scp "$MINI_HOST:~/src/whisper.cpp/build/ggml/src/libggml-cpu.so.0" "$WHISPER_LIB/"
    else
        dim "whisper libs already present"
    fi

    if [[ ! -f "$WHISPER_MODEL" ]]; then
        dim "Copying whisper model (base.en)..."
        scp "$MINI_HOST:~/.local/share/whisper/ggml-base.en.bin" "$WHISPER_MODEL"
    else
        dim "whisper model already present"
    fi

    # piper binary + bundled libs + espeak data
    if [[ ! -x "$PIPER_BIN" ]]; then
        dim "Copying piper + libraries..."
        scp "$MINI_HOST:~/src/piper/piper" "$PIPER_BIN"
        chmod +x "$PIPER_BIN"
        scp "$MINI_HOST":~/src/piper/lib*.so* "$PIPER_DIR/" 2>/dev/null || true
        rsync -a "$MINI_HOST:~/src/piper/espeak-ng-data/" "$PIPER_DIR/espeak-ng-data/"
    else
        dim "piper already present"
    fi

    # Voice model
    if [[ ! -f "$VOICE" ]]; then
        dim "Copying voice model..."
        scp "$MINI_HOST:~/.local/share/piper/voices/en_GB-alba-medium.onnx" "$VOICE"
        scp "$MINI_HOST:~/.local/share/piper/voices/en_GB-alba-medium.onnx.json" "${VOICE}.json" 2>/dev/null || true
    else
        dim "voice model already present"
    fi

    # Symlink piper into PATH
    if [[ ! -e "$LOCAL_BIN/piper" ]]; then
        ln -sf "$PIPER_BIN" "$LOCAL_BIN/piper"
    fi

    say "Setup complete. Run without --setup to start chatting."
    exit 0
fi

# ---------------------------------------------------------------------------
# Pre-flight
# ---------------------------------------------------------------------------
missing=()
for bin in arecord paplay sox ssh jq; do
    command -v "$bin" >/dev/null 2>&1 || missing+=("$bin")
done
[[ -x "$WHISPER_CLI" ]] || missing+=("whisper-cli (run $0 --setup)")
[[ -x "$PIPER_BIN" ]]   || missing+=("piper (run $0 --setup)")
[[ -f "$WHISPER_MODEL" ]] || missing+=("whisper model (run $0 --setup)")
[[ -f "$VOICE" ]]         || missing+=("piper voice (run $0 --setup)")

if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Missing dependencies:" >&2
    printf '  - %s\n' "${missing[@]}" >&2
    exit 1
fi

# Verify mini's ollama is reachable via SSH
ssh -o ConnectTimeout=3 "$MINI_HOST" "curl -sf http://127.0.0.1:$OLLAMA_PORT/api/tags >/dev/null" \
    || { echo "mini's ollama not responding" >&2; exit 1; }

# ---------------------------------------------------------------------------
# SSH tunnel: forward local $TUNNEL_PORT -> mini's ollama
# ---------------------------------------------------------------------------
dim "Opening SSH tunnel to mini's ollama on localhost:$TUNNEL_PORT..."
ssh -fNL "$TUNNEL_PORT:127.0.0.1:$OLLAMA_PORT" "$MINI_HOST"
TUNNEL_PID=$(pgrep -f "ssh -fNL $TUNNEL_PORT:127.0.0.1:$OLLAMA_PORT $MINI_HOST" | head -1)

TMPDIR_LOCAL=$(mktemp -d -t quokka-split.XXXXXX)
HISTORY_FILE="$TMPDIR_LOCAL/history.json"
PLAY_PID=""

QUIT=false
cleanup() {
    QUIT=true
    # Kill child processes by name rather than nuking the process group
    pkill -P $$ 2>/dev/null || true
    wait 2>/dev/null || true
    [[ -n "${TUNNEL_PID:-}" ]] && kill "$TUNNEL_PID" 2>/dev/null || true
    rm -rf "$TMPDIR_LOCAL"
    echo ""
    say "goodbye"
    exit 0
}
trap cleanup INT TERM
trap 'pkill -P $$ 2>/dev/null || true; wait 2>/dev/null || true; [[ -n "${TUNNEL_PID:-}" ]] && kill "$TUNNEL_PID" 2>/dev/null || true; rm -rf "$TMPDIR_LOCAL"' EXIT

# Verify tunnel works
sleep 0.5
curl -sf "http://127.0.0.1:$TUNNEL_PORT/api/tags" >/dev/null \
    || { echo "SSH tunnel to ollama failed" >&2; exit 1; }

OLLAMA_URL="http://127.0.0.1:$TUNNEL_PORT/api/chat"

SYSTEM_PROMPT='Your name is Quokka. You are a helpful voice assistant running locally on a Beelink mini-PC called mini. Your user is Rob. Keep spoken answers short — one to three sentences. When Rob asks you to write code, output ONLY the code with no explanation — it will be saved to a file. Start the code with a comment naming the language (e.g. # python, // javascript, -- lua). For non-code questions, answer conversationally. Avoid markdown formatting.'

reset_history() {
    echo "[{\"role\":\"system\",\"content\":$(printf '%s' "$SYSTEM_PROMPT" | jq -Rs .)}]" > "$HISTORY_FILE"
}
reset_history

sanitize_for_speech() {
    sed \
        -e 's/```[a-z]*//g' -e 's/```//g' \
        -e 's/\*\*\([^*]*\)\*\*/\1/g' -e 's/\*\([^*]*\)\*/\1/g' \
        -e 's/__\([^_]*\)__/\1/g' -e 's/_\([^_]*\)_/\1/g' \
        -e 's/`\([^`]*\)`/\1/g' \
        -e 's/^[[:space:]]*[-*][[:space:]]//g' \
        -e 's/^[[:space:]]*[0-9]\{1,\}\.[[:space:]]//g' \
        -e 's/^#\{1,\}[[:space:]]//g' \
        -e 's|https\{0,1\}://[^ ]*||g' \
        | tr -s ' \n' ' ' | sed 's/^ //; s/ $//'
}

stop_playback() {
    if [[ -n "${PLAY_PID:-}" ]] && kill -0 "$PLAY_PID" 2>/dev/null; then
        kill "$PLAY_PID" 2>/dev/null || true
        wait "$PLAY_PID" 2>/dev/null || true
    fi
    PLAY_PID=""
}

speak() {
    local text="$1"
    local clean
    clean=$(printf '%s' "$text" | sanitize_for_speech)
    local out="$TMPDIR_LOCAL/reply-$(date +%s%N).wav"
    LD_LIBRARY_PATH="${PIPER_DIR}:${LD_LIBRARY_PATH:-}" \
    ESPEAK_DATA_PATH="$PIPER_DIR" \
    "$PIPER_BIN" --model "$VOICE" --output_file "$out" <<< "$clean" >/dev/null 2>&1
    if [[ "$HANDS_FREE" == true ]]; then
        # Play in background so we can start listening for barge-in
        paplay "$out" 2>/dev/null &
        PLAY_PID=$!
        # Wait for playback to finish before listening again
        wait "$PLAY_PID" 2>/dev/null || true
        PLAY_PID=""
    else
        paplay "$out" 2>/dev/null
    fi
    rm -f "$out"
}

transcribe() {
    local wav="$1"
    LD_LIBRARY_PATH="$WHISPER_LIB:${LD_LIBRARY_PATH:-}" \
    "$WHISPER_CLI" -m "$WHISPER_MODEL" -f "$wav" -nt -np -otxt -of "$TMPDIR_LOCAL/transcript" 2>/dev/null
    cat "$TMPDIR_LOCAL/transcript.txt" 2>/dev/null | tr -s ' \n' ' ' | sed 's/^ //; s/ $//'
}

ask_ollama() {
    local user_text="$1"
    jq --arg c "$user_text" '. + [{"role":"user","content":$c}]' "$HISTORY_FILE" > "$HISTORY_FILE.tmp"
    mv "$HISTORY_FILE.tmp" "$HISTORY_FILE"

    local payload
    payload=$(jq -n --arg model "$MODEL" --slurpfile msgs "$HISTORY_FILE" \
        '{model:$model, messages:$msgs[0], stream:false, options:{num_ctx:4096}}')

    local resp
    resp=$(curl -sS -X POST "$OLLAMA_URL" \
        -H "Content-Type: application/json" -d "$payload")
    local reply
    reply=$(printf '%s' "$resp" | jq -r '.message.content // .error // "<empty>"')

    jq --arg c "$reply" '. + [{"role":"assistant","content":$c}]' "$HISTORY_FILE" > "$HISTORY_FILE.tmp"
    mv "$HISTORY_FILE.tmp" "$HISTORY_FILE"

    printf '%s' "$reply"
}

record_push_to_talk() {
    local out="$1"
    dim "Recording — press ENTER to stop..."
    arecord -q -f S16_LE -r 16000 -c 1 "$out" &
    local rec_pid=$!
    read -r _
    kill -INT "$rec_pid" 2>/dev/null; wait "$rec_pid" 2>/dev/null || true
}

record_hands_free() {
    # Records via sox silence detection: starts on voice onset, stops after silence.
    # arecord captures raw PCM; sox applies silence detection and outputs WAV.
    local out="$1"
    dim "Listening..."
    arecord -q -f S16_LE -r 16000 -c 1 -d "$SOX_MAX_DURATION" -t raw - 2>/dev/null \
    | sox -q -t raw -r 16000 -c 1 -b 16 -e signed-integer - \
          -t wav "$out" \
          silence 1 "$SOX_ONSET_DURATION" "$SOX_ONSET_THRESHOLD" \
                  1 "$SOX_SILENCE_DURATION" "$SOX_SILENCE_THRESHOLD" \
          2>/dev/null || true
}

# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------
say "quokka-split ready  model=$MODEL  (local STT/TTS, remote LLM)"
say "Audio stays on this machine. Only text goes to mini."
if [[ "$HANDS_FREE" == true ]]; then
    say "mode=hands-free (voice activity detection)"
    dim "Just talk — Ctrl-C to quit."
else
    dim "Press ENTER to speak, type /quit to exit, /new to reset."
fi

while [[ "$QUIT" == false ]]; do
    if [[ "$HANDS_FREE" == true ]]; then
        wav_file="$TMPDIR_LOCAL/rec-$(date +%s).wav"
        record_hands_free "$wav_file"
        [[ "$QUIT" == true ]] && break
    else
        printf '\n\033[2m> \033[0m'
        read -r line
        case "${line:-}" in
            /quit) say "goodbye"; break ;;
            /new)  reset_history; dim "conversation reset"; continue ;;
        esac
        wav_file="$TMPDIR_LOCAL/rec-$(date +%s).wav"
        record_push_to_talk "$wav_file"
    fi

    wav_size=$(stat -c%s "$wav_file" 2>/dev/null || echo 0)
    if [[ "$wav_size" -le 100 ]]; then
        dim "(empty recording, skipping)"
        continue
    fi

    # Transcribe locally
    dim "Transcribing..."
    text=$(transcribe "$wav_file")
    rm -f "$wav_file"
    if [[ -z "$text" || "$text" == "[BLANK_AUDIO]" ]]; then
        dim "(no speech detected)"
        continue
    fi
    user "you: $text"

    # Voice commands in hands-free mode
    if [[ "$HANDS_FREE" == true ]]; then
        case "$text" in
            *[Nn]ew\ conversation*|*[Rr]eset\ conversation*|*[Ss]tart\ over*)
                reset_history
                say "Conversation reset"
                speak "Conversation reset."
                continue ;;
        esac
    fi

    # LLM on mini (via tunnel)
    dim "Thinking..."
    reply=$(ask_ollama "$text")
    say "mini: $reply"

    # TTS locally
    speak "$reply"
done
