#!/usr/bin/env bash
# quokka-netcat-listen — start the netcat voice bridge listener on mini.
#
# Accepts one connection at a time via a FIFO pair, runs
# quokka-netcat-handler for each, then loops.
# Works with OpenBSD nc (no ncat required).
#
# Usage (on mini):
#   quokka-netcat-listen              # listen on port 9999
#   quokka-netcat-listen --port 8888
#   QUOKKA_MODEL=qwen2.5-coder:14b quokka-netcat-listen
#
# The workstation connects with: quokka-netcat

set -euo pipefail

PORT=9999
HANDLER="$(dirname "$(readlink -f "$0")")/quokka-netcat-handler"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --port) PORT="$2"; shift 2 ;;
        -h|--help) sed -n '2,13p' "$0"; exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 2 ;;
    esac
done

command -v nc >/dev/null 2>&1 || { echo "missing: nc" >&2; exit 1; }
[[ -x "$HANDLER" ]] || { echo "handler not found: $HANDLER" >&2; exit 1; }

WORKDIR=/tmp/quokka-netcat
mkdir -p "$WORKDIR"
FIFO_IN="$WORKDIR/fifo-in"
FIFO_OUT="$WORKDIR/fifo-out"

cleanup() {
    rm -f "$FIFO_IN" "$FIFO_OUT"
}
trap cleanup EXIT

# Clear stale history so each listener start is a fresh conversation
rm -f "$WORKDIR/history.json"

echo "quokka-netcat-listen: port=$PORT  model=${QUOKKA_MODEL:-llama3.1:8b}"
echo "Waiting for connections... (Ctrl-C to stop)"

while true; do
    rm -f "$FIFO_IN" "$FIFO_OUT"
    mkfifo "$FIFO_IN" "$FIFO_OUT"

    # Handler reads client audio from FIFO_IN, writes response to FIFO_OUT
    "$HANDLER" < "$FIFO_IN" > "$FIFO_OUT" &
    handler_pid=$!

    # nc bridges the network socket to the FIFOs
    # Client data → FIFO_IN → handler → FIFO_OUT → client
    nc -l -p "$PORT" < "$FIFO_OUT" > "$FIFO_IN" 2>/dev/null || true

    kill "$handler_pid" 2>/dev/null; wait "$handler_pid" 2>/dev/null || true
    echo "Connection handled, waiting for next..." >&2
done
