#!/usr/bin/env bash
# voice-agent — push-to-talk voice chat with a local LLM on mini.
#
# Pipeline: Blue Yeti mic → whisper.cpp STT → ollama chat → piper TTS → motherboard analog out.
#
# Usage:
#   voice-agent                  # default model llama3.1:8b, lessac voice
#   voice-agent --model qwen2.5-coder:14b
#   voice-agent --voice /path/to/voice.onnx
#
# Runtime controls inside the loop:
#   ENTER  — start recording; ENTER again — stop recording and send
#   /quit  — type this at the "listening" prompt to exit
#   /new   — reset the conversation history
#
# Hands-free mode (--hands-free):
#   Replaces ENTER-driven recording with sox silence detection.
#   Records when voice is detected, stops after silence returns.
#   Uses voice-engine/ec for echo cancellation so the user can
#   interrupt (barge-in) while quokka is speaking.
#   Designed for use via quokka-toggle (Gotify phone shortcut).
#   Requires: sox (apt install sox), ec (~/.local/bin/ec, run setup-ec)
#
# Dependencies (all on mini, no network beyond ollama loopback):
#   arecord, aplay             (alsa-utils)
#   ~/.local/bin/whisper-cli   (whisper.cpp)
#   ~/.local/share/whisper/ggml-base.en.bin
#   ~/.local/bin/piper
#   ~/.local/share/piper/voices/en_GB-alba-medium.onnx(+.json)
#   ollama on 127.0.0.1:11434 with llama3.1:8b loaded
#   ~/.local/bin/ec            (voice-engine/ec, hands-free only)
#
# This is X02 Phase 0: push-to-talk, no wake word, no streaming.

set -euo pipefail

MODEL="llama3.1:8b"
VOICE="$HOME/.local/share/piper/voices/en_GB-alba-medium.onnx"
WHISPER_MODEL="$HOME/.local/share/whisper/ggml-base.en.bin"
MIC_DEVICE="${VOICE_AGENT_MIC:-plughw:3,0}"
SPEAKER_DEVICE="${VOICE_AGENT_SPEAKER:-plughw:1,0}"
OLLAMA_URL="http://127.0.0.1:11434/api/chat"
HANDS_FREE=false
# Sox silence-detection thresholds (tune via env vars)
SOX_ONSET_DURATION="${VOICE_AGENT_ONSET:-0.3}"    # seconds of sound to start
SOX_ONSET_THRESHOLD="${VOICE_AGENT_ONSET_DB:-0.5%}" # volume to count as sound
SOX_SILENCE_DURATION="${VOICE_AGENT_SILENCE:-1.5}" # seconds of quiet to stop
SOX_SILENCE_THRESHOLD="${VOICE_AGENT_SILENCE_DB:-0.5%}"
SOX_MAX_DURATION="${VOICE_AGENT_MAX_REC:-30}"      # hard cap per utterance
# Echo-cancellation settings
EC_DELAY="${VOICE_AGENT_EC_DELAY:-100}"            # playback-to-mic delay (samples)
EC_INPUT="/tmp/ec.input"
EC_OUTPUT="/tmp/ec.output"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model)      MODEL="$2";   shift 2 ;;
        --voice)      VOICE="$2";   shift 2 ;;
        --whisper)    WHISPER_MODEL="$2"; shift 2 ;;
        --hands-free) HANDS_FREE=true; shift ;;
        -h|--help) sed -n '2,25p' "$0"; exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 2 ;;
    esac
done

# Pre-flight
for bin in arecord aplay curl jq ~/.local/bin/whisper-cli ~/.local/bin/piper; do
    if ! command -v "${bin/#\~/$HOME}" >/dev/null 2>&1; then
        echo "voice-agent: missing dependency: $bin" >&2
        exit 1
    fi
done
if [[ "$HANDS_FREE" == true ]]; then
    command -v sox >/dev/null 2>&1 || { echo "voice-agent: --hands-free requires sox (apt install sox)" >&2; exit 1; }
    [[ -x "$HOME/.local/bin/ec" ]] || { echo "voice-agent: --hands-free requires ec (run setup-ec)" >&2; exit 1; }
fi
[[ -r "$WHISPER_MODEL" ]] || { echo "voice-agent: whisper model not found: $WHISPER_MODEL" >&2; exit 1; }
[[ -r "$VOICE" ]]         || { echo "voice-agent: piper voice not found: $VOICE" >&2; exit 1; }

# Session state
TMPDIR_AGENT=$(mktemp -d -t voice-agent.XXXXXX)
HISTORY_FILE="$TMPDIR_AGENT/history.json"
CODE_DIR="$HOME/code"
LAST_SAVED_FILE=""
LAST_REPLY=""
PLAY_PID=""
EC_PID=""
DRAIN_PID=""
mkdir -p "$CODE_DIR"
SYSTEM_PROMPT="Your name is Quokka. You are a helpful voice assistant running locally on a Beelink mini-PC called mini. Your user is Rob. Keep spoken answers short — one to three sentences. When Rob asks you to write code, output ONLY the code with no explanation — it will be saved to a file. Start the code with a comment naming the language (e.g. # python, // javascript, -- lua). For non-code questions, answer conversationally. Avoid markdown formatting."
reset_history() { echo "[{\"role\":\"system\",\"content\":$(printf '%s' "$SYSTEM_PROMPT" | jq -Rs .)}]" > "$HISTORY_FILE"; }
reset_history

# Output helpers (defined early — needed by start_ec)
say() { printf '\033[1;36m%s\033[0m\n' "$*"; }
user() { printf '\033[1;33m%s\033[0m\n' "$*"; }
dim() { printf '\033[2m%s\033[0m\n' "$*"; }

# --- Echo cancellation (hands-free barge-in) ---------------------------------

start_ec() {
    # Create FIFOs ourselves, then open them O_RDWR so ec's unidirectional
    # opens don't deadlock waiting for the other end.
    rm -f "$EC_INPUT" "$EC_OUTPUT"
    mkfifo "$EC_INPUT" "$EC_OUTPUT"
    exec 7<>"$EC_INPUT"
    exec 8<>"$EC_OUTPUT"

    # ec flags: -i = playback device, -o = capture device (confusingly swapped)
    ~/.local/bin/ec -o "$MIC_DEVICE" -i "$SPEAKER_DEVICE" \
        -r 16000 -c 1 -d "$EC_DELAY" &
    EC_PID=$!
    sleep 1

    if ! kill -0 "$EC_PID" 2>/dev/null; then
        echo "voice-agent: ec failed to start" >&2
        exit 1
    fi

    say "echo-cancellation active (ec pid=$EC_PID)"
}

stop_ec() {
    if [[ -n "${EC_PID:-}" ]]; then
        kill "$EC_PID" 2>/dev/null || true
        wait "$EC_PID" 2>/dev/null || true
        EC_PID=""
    fi
    exec 7>&- 2>/dev/null || true
    exec 8<&- 2>/dev/null || true
    rm -f "$EC_INPUT" "$EC_OUTPUT"
}

start_drain() {
    # Continuously discard ec output so ec never blocks on a full pipe.
    cat <&8 >/dev/null &
    DRAIN_PID=$!
}

stop_drain() {
    if [[ -n "${DRAIN_PID:-}" ]]; then
        kill "$DRAIN_PID" 2>/dev/null || true
        wait "$DRAIN_PID" 2>/dev/null || true
        DRAIN_PID=""
    fi
}

cleanup() {
    stop_ec
    rm -rf "$TMPDIR_AGENT"
}
trap cleanup EXIT

# Start ec for hands-free mode
if [[ "$HANDS_FREE" == true ]]; then
    start_ec
fi

# --- Functions ----------------------------------------------------------------

detect_language() {
    local code="$1"
    local first_line
    first_line=$(head -1 <<< "$code")
    case "$first_line" in
        *python*|*Python*|"#!/usr/bin/env python"*|"#!/usr/bin/python"*)  echo "py" ;;
        *bash*|*Bash*|"#!/usr/bin/env bash"*|"#!/bin/bash"*)             echo "sh" ;;
        *javascript*|*JavaScript*|*node*)                                 echo "js" ;;
        *rust*|*Rust*)    echo "rs" ;;
        *go*|*Go*)        echo "go" ;;
        *lua*|*Lua*)      echo "lua" ;;
        *ruby*|*Ruby*)    echo "rb" ;;
        *)                echo "txt" ;;
    esac
}

save_code() {
    local code="$1"
    local ext
    ext=$(detect_language "$code")
    local ts
    ts=$(date +%Y%m%d-%H%M%S)
    LAST_SAVED_FILE="$CODE_DIR/quokka-${ts}.${ext}"
    printf '%s\n' "$code" > "$LAST_SAVED_FILE"
    [[ "$ext" == "sh" ]] && chmod +x "$LAST_SAVED_FILE"
    say "Saved: $LAST_SAVED_FILE"
    speak "Saved to $(basename "$LAST_SAVED_FILE")."
}

run_code() {
    local file="$1"
    if [[ -z "$file" || ! -f "$file" ]]; then
        speak "No file to run."
        return
    fi
    local ext="${file##*.}"
    local cmd
    case "$ext" in
        py)  cmd="python3 $file" ;;
        sh)  cmd="bash $file" ;;
        js)  cmd="node $file" ;;
        lua) cmd="lua $file" ;;
        rb)  cmd="ruby $file" ;;
        *)   speak "I don't know how to run a dot $ext file."; return ;;
    esac
    say "Running: $cmd"
    speak "Running it now."
    local output
    output=$(timeout 30 $cmd 2>&1) || true
    if [[ -z "$output" ]]; then
        speak "It finished with no output."
    else
        say "output: $output"
        local short
        short=$(head -c 500 <<< "$output")
        speak "$short"
    fi
}

sanitize_for_speech() {
    sed \
        -e 's/```[a-z]*//g' -e 's/```//g' \
        -e 's/\*\*\([^*]*\)\*\*/\1/g' \
        -e 's/\*\([^*]*\)\*/\1/g' \
        -e 's/__\([^_]*\)__/\1/g' \
        -e 's/_\([^_]*\)_/\1/g' \
        -e 's/`\([^`]*\)`/\1/g' \
        -e 's/^[[:space:]]*[-*][[:space:]]//g' \
        -e 's/^[[:space:]]*[0-9]\{1,\}\.[[:space:]]//g' \
        -e 's/^#\{1,\}[[:space:]]//g' \
        -e 's|https\{0,1\}://[^ ]*||g' \
        | tr -s ' \n' ' ' | sed 's/^ //; s/ $//'
}

stop_playback() {
    if [[ -n "${PLAY_PID:-}" ]] && kill -0 "$PLAY_PID" 2>/dev/null; then
        kill "$PLAY_PID" 2>/dev/null || true
        wait "$PLAY_PID" 2>/dev/null || true
    fi
    PLAY_PID=""
}

speak() {
    local text="$1"
    local clean
    clean=$(printf '%s' "$text" | sanitize_for_speech)
    local out="$TMPDIR_AGENT/reply-$(date +%s%N).wav"
    printf '%s' "$clean" | ~/.local/bin/piper \
        --model "$VOICE" \
        --output_file "$out" >/dev/null 2>&1
    if [[ -n "${EC_PID:-}" ]] && kill -0 "$EC_PID" 2>/dev/null; then
        # Write raw audio to ec's input pipe. ec plays it through the speaker
        # AND uses it as the reference signal for echo cancellation.
        # Non-blocking: main loop starts listening immediately (barge-in).
        sox "$out" -t raw -r 16000 -c 1 -b 16 -e signed-integer - >&7 &
        PLAY_PID=$!
    else
        aplay -q -D "$SPEAKER_DEVICE" "$out" 2>/dev/null || true
        rm -f "$out"
    fi
}

record_until_enter() {
    local out="$1"
    dim "Recording — press ENTER to stop..."
    arecord -q -D "$MIC_DEVICE" -f S16_LE -r 16000 -c 1 "$out" &
    local rec_pid=$!
    read -r _ || true
    kill -INT "$rec_pid" 2>/dev/null || true
    wait "$rec_pid" 2>/dev/null || true
}

record_until_silence() {
    # Records until trailing silence is detected via sox.
    # In ec mode, reads echo-cancelled audio from the ec output pipe.
    # In direct mode, reads raw PCM from arecord via ALSA.
    local out="$1"
    local onset_thresh="${2:-$SOX_ONSET_THRESHOLD}"
    dim "Listening..."
    if [[ -n "${EC_PID:-}" ]] && kill -0 "$EC_PID" 2>/dev/null; then
        # Pause the drain so we get the audio, not /dev/null
        stop_drain
        timeout "$SOX_MAX_DURATION" cat <&8 2>/dev/null \
        | sox -q -t raw -r 16000 -c 1 -b 16 -e signed-integer - \
              -t wav "$out" \
              silence 1 "$SOX_ONSET_DURATION" "$onset_thresh" \
                      1 "$SOX_SILENCE_DURATION" "$SOX_SILENCE_THRESHOLD" \
              2>/dev/null || true
        # Resume drain to keep ec healthy
        start_drain
    else
        arecord -q -D "$MIC_DEVICE" -f S16_LE -r 16000 -c 1 -d "$SOX_MAX_DURATION" -t raw - 2>/dev/null \
        | sox -q -t raw -r 16000 -c 1 -b 16 -e signed-integer - \
              -t wav "$out" \
              silence 1 "$SOX_ONSET_DURATION" "$onset_thresh" \
                      1 "$SOX_SILENCE_DURATION" "$SOX_SILENCE_THRESHOLD" \
              2>/dev/null || true
    fi
}

transcribe() {
    local wav="$1"
    ~/.local/bin/whisper-cli \
        -m "$WHISPER_MODEL" \
        -f "$wav" \
        -nt -np -otxt -of "$TMPDIR_AGENT/transcript" 2>/dev/null
    local raw
    raw=$(cat "$TMPDIR_AGENT/transcript.txt" 2>/dev/null | tr -s ' \n' ' ' | sed 's/^ //; s/ $//')
    printf '%s' "$raw" | sed \
        -e 's/\b[Ss]ay [Ii]n [Oo]ur [Ff]ather/say an Our Father/g' \
        -e 's/\b[Aa]rbo\b/arvo/g' \
        -e 's/\b[Oo]ur [Ff]ather\b/Our Father/g'
}

ask_ollama() {
    local user_text="$1"
    jq --arg c "$user_text" '. + [{"role":"user","content":$c}]' "$HISTORY_FILE" > "$HISTORY_FILE.tmp"
    mv "$HISTORY_FILE.tmp" "$HISTORY_FILE"

    local payload
    payload=$(jq -n --arg model "$MODEL" --slurpfile msgs "$HISTORY_FILE" \
        '{model:$model, messages:$msgs[0], stream:false, options:{num_ctx:4096}}')

    local resp
    resp=$(curl -sS -X POST "$OLLAMA_URL" \
        -H "Content-Type: application/json" \
        -d "$payload")
    local reply
    reply=$(printf '%s' "$resp" | jq -r '.message.content // .error // "<empty>"')

    jq --arg c "$reply" '. + [{"role":"assistant","content":$c}]' "$HISTORY_FILE" > "$HISTORY_FILE.tmp"
    mv "$HISTORY_FILE.tmp" "$HISTORY_FILE"

    printf '%s' "$reply"
}

ask_claude() {
    local user_text="$1"
    local reply
    reply=$(timeout 120 claude -p "$user_text" --max-turns 10 \
        --allowedTools "Bash" "Read" "Write" "Edit" "Glob" "Grep" "WebSearch" "WebFetch" \
        2>/dev/null) || true
    if [[ -z "$reply" ]]; then
        reply="Sorry, I didn't get a response from Claude."
    fi
    printf '%s' "$reply"
}

ask_model() {
    local user_text="$1"
    if [[ "$MODEL" == "claude" ]]; then
        ask_claude "$user_text"
    else
        ask_ollama "$user_text"
    fi
}

# --- Main loop ----------------------------------------------------------------

say "voice-agent ready — model=$MODEL voice=$(basename "$VOICE" .onnx)"
say "mic=$MIC_DEVICE speaker=$SPEAKER_DEVICE"
if [[ "$HANDS_FREE" == true ]]; then
    say "mode=hands-free (sox + ec barge-in)"
    dim "Listening for speech — kill the process or send Gotify toggle to stop."
else
    dim "Press ENTER to speak, type /quit to exit, /new to reset conversation."
fi

while true; do
    if [[ "$HANDS_FREE" == true ]]; then
        wav="$TMPDIR_AGENT/rec-$(date +%s).wav"
        record_until_silence "$wav"
        stop_playback   # barge-in: kill TTS feed if user spoke over it
    else
        printf '\n\033[2m> \033[0m'
        read -r line
        case "$line" in
            /quit) say "goodbye"; break ;;
            /new)  reset_history; dim "conversation reset"; continue ;;
        esac

        wav="$TMPDIR_AGENT/rec-$(date +%s).wav"
        record_until_enter "$wav"
    fi

    # A WAV header alone is 44 bytes — treat anything ≤ 100 bytes as empty.
    wav_size=$(stat -c%s "$wav" 2>/dev/null || echo 0)
    if [[ "$wav_size" -le 100 ]]; then
        dim "(empty recording, skipping)"
        rm -f "$wav"
        continue
    fi

    dim "Transcribing..."
    text=$(transcribe "$wav")
    if [[ -z "$text" || "$text" == "[BLANK_AUDIO]" ]]; then
        dim "(no speech detected)"
        continue
    fi
    user "you: $text"

    # Voice commands: model switching and conversation reset.
    case "$text" in
        *[Ss]witch\ to\ code*|*[Ss]witch\ to\ coder*|*[Uu]se\ the\ coder*|*[Uu]se\ coder*)
            MODEL="qwen2.5-coder:14b"
            say "Switched to $MODEL"
            speak "Done. I'm now using the coding model, qwen 2.5 coder."
            continue ;;
        *[Ss]witch\ to\ [Cc]laude*|*[Uu]se\ [Cc]laude*)
            MODEL="claude"
            say "Switched to $MODEL"
            speak "Done. I'm now using Claude. I can read files, run commands, and edit code."
            continue ;;
        *[Ss]witch\ to\ chat*|*[Ss]witch\ to\ normal*|*[Uu]se\ chat*|*[Ss]witch\ to\ local*)
            MODEL="llama3.1:8b"
            say "Switched to $MODEL"
            speak "Done. I'm now using the local chat model, llama 3.1."
            continue ;;
        *[Rr]eset\ conversation*|*[Ss]tart\ over*|*[Nn]ew\ conversation*)
            reset_history
            say "Conversation reset"
            speak "Conversation reset."
            continue ;;
        *[Ww]hat\ model*|*[Ww]hich\ model*)
            speak "I'm currently using $MODEL."
            continue ;;
        *[Ss]ave\ that*|*[Ww]rite\ that*|*[Ss]ave\ the\ code*|*[Ss]ave\ it*)
            if [[ -z "$LAST_REPLY" ]]; then
                speak "There's nothing to save yet."
            else
                save_code "$LAST_REPLY"
            fi
            continue ;;
        *[Rr]un\ that*|*[Rr]un\ it*|*[Ee]xecute\ that*|*[Ee]xecute\ it*)
            run_code "$LAST_SAVED_FILE"
            continue ;;
    esac

    dim "Thinking..."
    reply=$(ask_model "$text")
    LAST_REPLY="$reply"
    say "mini: $reply"

    # Auto-save: if the reply looks like code (starts with # or //)
    first_char=$(head -c 1 <<< "$reply")
    if [[ "$first_char" == "#" || "$reply" == "//"* || "$reply" == "#!/"* ]]; then
        save_code "$reply"
        speak "I've written that code and saved it. Say run it to execute."
    else
        speak "$reply"
    fi
done
